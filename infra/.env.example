# Copy to .env and fill in real values. .env is gitignored.

# --- Postgres (shared by Airflow + MLflow, separate logical DBs) ---
POSTGRES_USER=CHANGEME
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=CHANGEME

# --- Airflow admin ---
AIRFLOW_ADMIN_USER=CHANGEME
AIRFLOW_ADMIN_PASSWORD=CHANGEME
AIRFLOW_ADMIN_EMAIL=CHANGEME
AIRFLOW_SECRET_KEY=CHANGEME
# --- Airflow JWT secret (signs inter-component tokens in Airflow 3). Rotate per env. ---
AIRFLOW_JWT_SECRET=CHANGEME

# --- Airflow Fernet key (encrypts connections + variables at rest).
# Rotating this invalidates existing encrypted values in the metadata DB.
AIRFLOW_FERNET_KEY=CHANGEME

# Run Airflow containers as the host user so bind-mounted
# ./airflow/{logs,dags,plugins} are writable. `id -u` on host.
AIRFLOW_UID=CHANGEME

# --- Host IP for browser-facing iframe URLs (Ray dashboard embeds Grafana panels via host browser) ---
HOST_IP=CHANGEME

# --- AWS / EKS: target for retrain_on_drift's redeploy_inference_api task ---
# The inference API is the only medi-watch workload on k8s. On a new @champion the
# Airflow worker runs `aws eks update-kubeconfig` + `kubectl rollout restart`
# against this cluster. Leave EKS_CLUSTER_NAME / AWS_REGION empty to disable the
# redeploy (the task skips). Provide creds here OR via a mounted ~/.aws (see
# docker-compose volumes). Full setup: infra/aws/README.md.
EKS_CLUSTER_NAME=CHANGEME
AWS_REGION=CHANGEME
K8S_NAMESPACE=CHANGEME
INFERENCE_DEPLOYMENT=CHANGEME
# Local k8s path: when set, redeploy_inference_api targets this kubectl context
# (a local minikube/kind cluster) instead of EKS, with no aws/creds step.
LOCAL_KUBE_CONTEXT=CHANGEME
AWS_ACCESS_KEY_ID=CHANGEME
AWS_SECRET_ACCESS_KEY=CHANGEME
AWS_SESSION_TOKEN=CHANGEME

#ANTHROPIC=CHANGEME
#OPEN_AI=CHANGEME
#XAI=CHANGEME

# --- MediWatch app data (shared `mediwatch` logical DB on the same Postgres) ---
# Local conda pipeline reaches the container via the exposed 127.0.0.1:5432 port.
# In-container services override the host to `postgres` via docker-compose.
MEDIWATCH_DB_URL=CHANGEME